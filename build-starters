#!/bin/sh
# build-starters: rebuild deploy/allspeak-<lang>.zip from starter/<lang>/.
#
# Each starter zip bundles the language-specific bootstrap files
# (CLAUDE.md, server.as, edit.html) with the shared editor
# (asedit.as, asedit.json) at the zip root.
#
# Run after editing anything under starter/ or after changing
# asedit.as / asedit.json. Languages are auto-discovered from
# starter/*/ subdirectories.

set -eu
cd "$(dirname "$0")"

if [ ! -f asedit.as ] || [ ! -f asedit.json ]; then
    echo "Error: asedit.as / asedit.json not found in repo root." >&2
    exit 1
fi

if ! command -v zip >/dev/null 2>&1; then
    echo "Error: 'zip' command not found." >&2
    exit 1
fi

mkdir -p deploy

STAGE=$(mktemp -d)
trap 'rm -rf "$STAGE"' EXIT

built=0
for dir in starter/*/; do
    lang=$(basename "$dir")
    missing=
    for f in CLAUDE.md server.as edit.html; do
        [ -f "$dir$f" ] || missing="$missing $f"
    done
    if [ -n "$missing" ]; then
        echo "  skip: starter/$lang missing:$missing"
        continue
    fi

    work="$STAGE/$lang"
    mkdir -p "$work"
    cp -p "$dir"CLAUDE.md "$dir"server.as "$dir"edit.html "$work/"
    cp -p asedit.as asedit.json "$work/"

    out="$PWD/deploy/allspeak-$lang.zip"
    rm -f "$out"
    ( cd "$work" && zip -q "$out" CLAUDE.md server.as edit.html asedit.json asedit.as )

    echo "  built: deploy/allspeak-$lang.zip"
    built=$((built + 1))
done

echo "Done. $built starter packs rebuilt."
