{
  "#doc": "AllSpeak Primer - mise en page française via Webson",
  "#element": "div",
  "@id": "PrimerPage",
  "position": "relative",
  "width": "100%",
  "height": "100%",
  "min-height": "100%",
  "box-sizing": "border-box",
  "display": "flex",
  "flex-direction": "column",
  "background": "#0f1923",
  "color": "#eaf0ff",
  "font-family": "Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif",
  "font-size": "16px",
  "line-height": "1.5",
  "overflow-y": "auto",
  "padding": "0.9em",
  "gap": "0.9em",
  "#": [
    "$TitleBar",
    "$TabBar",
    "$StartContainer",
    "$ExampleContainer",
    "$ManualContainer"
  ],

  "$TitleBar": {
    "#element": "div",
    "@id": "TitleBar",
    "display": "flex",
    "align-items": "center",
    "gap": "0.7em",
    "padding": "0.4em 0.2em",
    "border-bottom": "1px solid #253545",
    "margin-bottom": "0.2em",
    "#": [
      "$TitleLogo",
      "$TitleText"
    ],

    "$TitleLogo": {
      "#element": "img",
      "@id": "TitleLogo",
      "@src": "primer/duckthink.png",
      "width": "40px",
      "height": "40px",
      "border-radius": "8px"
    },

    "$TitleText": {
      "#element": "div",
      "@id": "TitleText",
      "#content": "Programmer avec AllSpeak et l'IA",
      "font-size": "1.4em",
      "font-weight": "700",
      "letter-spacing": "0.02em",
      "color": "#9cc5ff"
    }
  },

  "$TabBar": {
    "#element": "div",
    "@id": "TabBar",
    "display": "flex",
    "gap": "0.5em",
    "margin-bottom": "0.1em",
    "#": [
      "$TabStart",
      "$TabExample",
      "$TabManual",
      "$TabCodex"
    ],

    "$TabStart": {
      "#element": "button",
      "@id": "TabStart",
      "#content": "Démarrer",
      "background": "#1e3450",
      "color": "#eaf0ff",
      "border": "1px solid #253545",
      "border-radius": "9px",
      "padding": "0.55em 0.9em",
      "font-weight": "600",
      "cursor": "pointer"
    },

    "$TabExample": {
      "#element": "button",
      "@id": "TabExample",
      "#content": "Exemple",
      "background": "#0b1018",
      "color": "#eaf0ff",
      "border": "1px solid #253545",
      "border-radius": "9px",
      "padding": "0.55em 0.9em",
      "font-weight": "600",
      "cursor": "pointer"
    },

    "$TabManual": {
      "#element": "button",
      "@id": "TabManual",
      "#content": "Manuel IA",
      "background": "#0b1018",
      "color": "#eaf0ff",
      "border": "1px solid #253545",
      "border-radius": "9px",
      "padding": "0.55em 0.9em",
      "font-weight": "600",
      "cursor": "pointer"
    },

    "$TabCodex": {
      "#element": "button",
      "@id": "TabCodex",
      "#content": "Codex",
      "background": "#0b1018",
      "color": "#eaf0ff",
      "border": "1px solid #253545",
      "border-radius": "9px",
      "padding": "0.55em 0.9em",
      "font-weight": "600",
      "cursor": "pointer"
    }
  },

  "$StartContainer": {
    "#element": "div",
    "@id": "StartContainer",
    "display": "flex",
    "flex-direction": "column",
    "gap": "0.6em",
    "#": [
      "$StartCard"
    ],

    "$StartCard": {
      "#element": "div",
      "@id": "StartCard",
      "@data-markdown": "1",
      "padding": "1em",
      "color": "#eaf0ff"
    }
  },

  "$ExampleContainer": {
    "#element": "div",
    "@id": "ExampleContainer",
    "display": "none",
    "flex-direction": "column",
    "gap": "0.6em",
    "#": [
      "$ExampleCard"
    ],

    "$ExampleCard": {
      "#element": "div",
      "@id": "ExampleCard",
      "@data-markdown": "1",
      "padding": "1em",
      "color": "#eaf0ff"
    }
  },

  "$ManualContainer": {
    "#element": "div",
    "@id": "ManualContainer",
    "display": "none",
    "flex-direction": "column",
    "gap": "0.6em",
    "#": [
      "$ManualStatus",
      "$RetryManualButton",
      "$ManualChapterList",
      "$ManualBackButton",
      "$ManualBody"
    ],

    "$ManualStatus": {
      "#element": "div",
      "@id": "ManualStatus",
      "#content": "",
      "color": "#b8c2df"
    },

    "$RetryManualButton": {
      "#element": "button",
      "@id": "RetryManualButton",
      "#content": "Réessayer le chargement",
      "display": "none",
      "background": "#1e3450",
      "color": "#eaf0ff",
      "border": "1px solid #253545",
      "border-radius": "9px",
      "padding": "0.5em 0.8em",
      "font-weight": "600",
      "cursor": "pointer",
      "margin-bottom": "0.2em",
      "width": "fit-content"
    },

    "$ManualChapterList": {
      "#element": "div",
      "@id": "ManualChapterList",
      "display": "flex",
      "flex-direction": "column",
      "gap": "0.35em",
      "margin-bottom": "0.35em",
      "#": [
        "$ManualChapter1",
        "$ManualChapter2",
        "$ManualChapter3",
        "$ManualChapter4",
        "$ManualChapter5",
        "$ManualChapter6",
        "$ManualChapter7",
        "$ManualChapter8"
      ],

      "$ManualChapter1": {
        "#element": "button",
        "@id": "ManualChapter1",
        "#content": "Chapitre 1 — Développement web natif pour l'IA",
        "background": "#0b1018",
        "color": "#9cc5ff",
        "border": "1px solid #253545",
        "border-radius": "9px",
        "padding": "0.5em 0.7em",
        "text-align": "left",
        "cursor": "pointer"
      },

      "$ManualChapter2": {
        "#element": "button",
        "@id": "ManualChapter2",
        "#content": "Chapitre 2 — Cadre de décision",
        "background": "#0b1018",
        "color": "#9cc5ff",
        "border": "1px solid #253545",
        "border-radius": "9px",
        "padding": "0.5em 0.7em",
        "text-align": "left",
        "cursor": "pointer"
      },

      "$ManualChapter3": {
        "#element": "button",
        "@id": "ManualChapter3",
        "#content": "Chapitre 3 — Flux de livraison",
        "background": "#0b1018",
        "color": "#9cc5ff",
        "border": "1px solid #253545",
        "border-radius": "9px",
        "padding": "0.5em 0.7em",
        "text-align": "left",
        "cursor": "pointer"
      },

      "$ManualChapter4": {
        "#element": "button",
        "@id": "ManualChapter4",
        "#content": "Chapitre 4 — Dépannage et stabilisation",
        "background": "#0b1018",
        "color": "#9cc5ff",
        "border": "1px solid #253545",
        "border-radius": "9px",
        "padding": "0.5em 0.7em",
        "text-align": "left",
        "cursor": "pointer"
      },

      "$ManualChapter5": {
        "#element": "button",
        "@id": "ManualChapter5",
        "#content": "Chapitre 5 — Du MVP aux habitudes de production",
        "background": "#0b1018",
        "color": "#9cc5ff",
        "border": "1px solid #253545",
        "border-radius": "9px",
        "padding": "0.5em 0.7em",
        "text-align": "left",
        "cursor": "pointer"
      },

      "$ManualChapter6": {
        "#element": "button",
        "@id": "ManualChapter6",
        "#content": "Chapitre 6 — Guide d'équipe",
        "background": "#0b1018",
        "color": "#9cc5ff",
        "border": "1px solid #253545",
        "border-radius": "9px",
        "padding": "0.5em 0.7em",
        "text-align": "left",
        "cursor": "pointer"
      },

      "$ManualChapter7": {
        "#element": "button",
        "@id": "ManualChapter7",
        "#content": "Chapitre 7 — Ingénierie des prompts",
        "background": "#0b1018",
        "color": "#9cc5ff",
        "border": "1px solid #253545",
        "border-radius": "9px",
        "padding": "0.5em 0.7em",
        "text-align": "left",
        "cursor": "pointer"
      },

      "$ManualChapter8": {
        "#element": "button",
        "@id": "ManualChapter8",
        "#content": "Chapitre 8 — Développement structuré vs vibe coding",
        "background": "#0b1018",
        "color": "#9cc5ff",
        "border": "1px solid #253545",
        "border-radius": "9px",
        "padding": "0.5em 0.7em",
        "text-align": "left",
        "cursor": "pointer"
      }
    },

    "$ManualBackButton": {
      "#element": "button",
      "@id": "ManualBackButton",
      "#content": "Retour",
      "display": "none",
      "background": "#1e3450",
      "color": "#eaf0ff",
      "border": "1px solid #253545",
      "border-radius": "9px",
      "padding": "0.5em 0.8em",
      "font-weight": "600",
      "cursor": "pointer",
      "margin-bottom": "0.2em",
      "width": "fit-content"
    },

    "$ManualBody": {
      "#element": "div",
      "@id": "ManualBody",
      "@data-markdown": "1",
      "padding": "1em",
      "color": "#eaf0ff"
    }
  }
}
