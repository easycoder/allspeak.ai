{
  "$OpenBtn": {
    "#element": "button",
    "@id": "se-open",
    "#content": "Open",
    "padding": "4px 12px",
    "cursor": "pointer"
  },
  "$TabBar": {
    "#element": "div",
    "@id": "se-tabbar",
    "display": "flex",
    "gap": "2px",
    "overflow-x": "auto",
    "min-width": "0"
  },
  "$PlusBtn": {
    "#element": "img",
    "@id": "se-plusbtn",
    "@src": "https://allspeak.ai/resources/icon/plus.png",
    "width": "20px",
    "height": "20px",
    "cursor": "pointer",
    "padding": "4px",
    "flex-shrink": "0"
  },
  "$TabGroup": {
    "#element": "div",
    "@id": "se-tabgroup",
    "display": "flex",
    "flex": "1",
    "align-items": "center",
    "min-width": "0",
    "#": ["$TabBar", "$PlusBtn"]
  },
  "$FindBtn": {
    "#element": "button",
    "@id": "se-findbtn",
    "#content": "Find",
    "padding": "4px 12px",
    "cursor": "pointer",
    "flex-shrink": "0"
  },
  "$StatusSpan": {
    "#element": "span",
    "@id": "se-status",
    "color": "lightgreen",
    "font-size": "0.85em",
    "padding": "0 8px",
    "white-space": "nowrap",
    "min-width": "6em",
    "text-align": "right"
  },
  "$Logo": {
    "#element": "img",
    "@id": "se-logo",
    "@src": "https://allspeak.ai/resources/icon/duckthink.png",
    "width": "28px",
    "height": "28px",
    "border-radius": "6px",
    "flex-shrink": "0"
  },
  "$TopBar": {
    "#element": "div",
    "@id": "se-topbar",
    "display": "flex",
    "align-items": "center",
    "background": "#2d2d2d",
    "padding": "4px",
    "gap": "4px",
    "#": ["$Logo", "$OpenBtn", "$TabGroup", "$StatusSpan", "$FindBtn"]
  },
  "$ContentEditor": {
    "#element": "textarea",
    "@id": "se-textarea",
    "width": "100%",
    "height": "100%"
  },
  "$ContentDiv": {
    "#element": "div",
    "width": "100%",
    "height": "100%",
    "#": ["$ContentEditor"]
  },
  "$EditorArea": {
    "#element": "div",
    "height": "calc(100vh - 40px)",
    "#": ["$ContentDiv"]
  },
  "$Scroller": {
    "#element": "div",
    "@id": "se-scroller",
    "flex": "1",
    "overflow-y": "auto",
    "margin-bottom": "0.5em",
    "min-height": "100px"
  },
  "$CloseBtn": {
    "#element": "button",
    "@id": "se-closebtn",
    "#content": "Close"
  },
  "$FileListing": {
    "#element": "div",
    "position": "absolute",
    "width": "50%",
    "max-height": "70%",
    "background": "white",
    "padding": "1em",
    "top": "50%",
    "left": "50%",
    "transform": "translateX(-50%) translateY(-50%)",
    "display": "flex",
    "flex-direction": "column",
    "border-radius": "4px",
    "#": ["$Scroller", "$CloseBtn"]
  },
  "$Overlay": {
    "#element": "div",
    "@id": "se-overlay",
    "display": "none",
    "position": "fixed",
    "top": "0",
    "left": "0",
    "width": "100vw",
    "height": "100vh",
    "background": "rgba(0,0,0,0.5)",
    "z-index": "100",
    "#": ["$FileListing"]
  },
  "#": ["$TopBar", "$EditorArea", "$Overlay"]
}
