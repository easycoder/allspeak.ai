#!/bin/sh
# deploy-sync: mirror source-tree changes into deploy/ for serving.
#
# Run this after:
#   - editing anything under codex/, learn/, primer/
#   - editing primer.html (or any tracked root HTML file)
#   - running ./build-allspeak (which rewrites dist/)
#   - adding or regenerating docs under resources/doc/
#
# Uses rsync when available (preserves timestamps, only copies changes)
# and falls back to cp -r. Safe to re-run at any time.
#
# For a full end-to-end refresh (sync packs + build JS + build zips + sync),
# use ./deploy instead.

set -eu
cd "$(dirname "$0")"

if command -v rsync >/dev/null 2>&1; then
    SYNC="rsync -a --delete"
else
    SYNC="cp_r_clobber"
    cp_r_clobber() {
        # $1 = source dir (must end with /), $2 = destination dir
        rm -rf "$2"
        mkdir -p "$2"
        cp -r "$1". "$2"
    }
fi

run_sync() {
    src="$1"
    dst="$2"
    shift 2
    if [ ! -d "$src" ]; then
        echo "  skip: $src does not exist"
        return
    fi
    mkdir -p "$dst"
    if [ "$SYNC" = "cp_r_clobber" ]; then
        # NOTE: the cp_r_clobber fallback path does not honour rsync excludes.
        cp_r_clobber "$src" "$dst"
    else
        $SYNC "$@" "$src" "$dst"
    fi
    echo "  synced: $src -> $dst"
}

copy_file() {
    src="$1"
    dst="$2"
    if [ ! -f "$src" ]; then
        echo "  skip: $src does not exist"
        return
    fi
    cp -p "$src" "$dst"
    echo "  copied: $src -> $dst"
}

echo "Syncing source -> deploy/"
run_sync "codex/"           "deploy/codex/"
run_sync "learn/"           "deploy/learn/"
# The English-language Primer reads its assets from /en/primer/. Source primer/
# is the single source of truth (project.as is the feature-rich script,
# strings.json is the English locale, duckthink.png is present, project.json
# has deploy-friendly paths). The de/, fr/, it/ directories hold translated
# copies and are NOT touched here — translate them as a separate pass.
# README.md is dev-only. project.as is excluded because /en/primer.html loads
# /shared/primer/project.as, not /en/primer/project.as — copying it here would
# leave an unused duplicate.
run_sync "primer/"          "deploy/en/primer/" --exclude=README.md --exclude=project.as
run_sync "dist/"            "deploy/dist/"
run_sync "resources/doc/"   "deploy/resources/doc/"

# The four language Primer pages all load /shared/primer/project.as. Keep that
# single file in sync with source so we have one canonical script.
copy_file "primer/project.as" "deploy/shared/primer/project.as"

echo "Done."
