#!/bin/sh

echo "Copy the various files"
cd "$(dirname "$0")"
rm -rf deploy/dist/*
mkdir deploy/dist/plugins
mkdir -p deploy/dist/vendor/showdown
cp -r js/plugins/* deploy/dist/plugins

echo "Static build: skip server-side assets (PHP/Python)"

echo "Ensure showdown runtime library is available"
if [ -f vendor/showdown/showdown.min.js ]; then
	cp vendor/showdown/showdown.min.js deploy/dist/vendor/showdown/showdown.min.js
elif command -v curl >/dev/null 2>&1; then
	curl -fsSL https://cdn.jsdelivr.net/npm/showdown@2.1.0/dist/showdown.min.js \
		-o deploy/dist/vendor/showdown/showdown.min.js
elif command -v wget >/dev/null 2>&1; then
	wget -q -O deploy/dist/vendor/showdown/showdown.min.js \
		https://cdn.jsdelivr.net/npm/showdown@2.1.0/dist/showdown.min.js
else
	echo "Warning: Could not fetch showdown.min.js (curl/wget not found)."
	echo "Codex showdown decode will fail until deploy/dist/vendor/showdown/showdown.min.js exists."
fi

echo "Ensure CodeMirror addon assets are available"
mkdir -p deploy/dist/plugins/codemirror/addon/dialog
mkdir -p deploy/dist/plugins/codemirror/addon/search

if [ -f vendor/codemirror/addon/dialog/dialog.css ]; then
	cp vendor/codemirror/addon/dialog/dialog.css deploy/dist/plugins/codemirror/addon/dialog/dialog.css
	cp vendor/codemirror/addon/dialog/dialog.js deploy/dist/plugins/codemirror/addon/dialog/dialog.js
	cp vendor/codemirror/addon/search/search.js deploy/dist/plugins/codemirror/addon/search/search.js
	cp vendor/codemirror/addon/search/searchcursor.js deploy/dist/plugins/codemirror/addon/search/searchcursor.js
	cp vendor/codemirror/addon/search/jump-to-line.js deploy/dist/plugins/codemirror/addon/search/jump-to-line.js
elif command -v curl >/dev/null 2>&1; then
	curl -fsSL https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.46.0/addon/dialog/dialog.css \
		-o deploy/dist/plugins/codemirror/addon/dialog/dialog.css
	curl -fsSL https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.46.0/addon/dialog/dialog.js \
		-o deploy/dist/plugins/codemirror/addon/dialog/dialog.js
	curl -fsSL https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.46.0/addon/search/search.js \
		-o deploy/dist/plugins/codemirror/addon/search/search.js
	curl -fsSL https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.46.0/addon/search/searchcursor.js \
		-o deploy/dist/plugins/codemirror/addon/search/searchcursor.js
	curl -fsSL https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.46.0/addon/search/jump-to-line.js \
		-o deploy/dist/plugins/codemirror/addon/search/jump-to-line.js
elif command -v wget >/dev/null 2>&1; then
	wget -q -O deploy/dist/plugins/codemirror/addon/dialog/dialog.css \
		https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.46.0/addon/dialog/dialog.css
	wget -q -O deploy/dist/plugins/codemirror/addon/dialog/dialog.js \
		https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.46.0/addon/dialog/dialog.js
	wget -q -O deploy/dist/plugins/codemirror/addon/search/search.js \
		https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.46.0/addon/search/search.js
	wget -q -O deploy/dist/plugins/codemirror/addon/search/searchcursor.js \
		https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.46.0/addon/search/searchcursor.js
	wget -q -O deploy/dist/plugins/codemirror/addon/search/jump-to-line.js \
		https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.46.0/addon/search/jump-to-line.js
else
	echo "Warning: Could not fetch CodeMirror addons (curl/wget not found)."
	echo "Codex search/dialog features will fail until deploy/dist/plugins/codemirror/addon/* exists."
fi

echo "Merge into a single file"
cat js/allspeak/Core.js js/allspeak/Browser.js js/allspeak/MarkdownRenderer.js js/allspeak/Webson.js js/allspeak/JSON.js js/allspeak/MQTT.js js/allspeak/REST.js js/allspeak/Compare.js js/allspeak/Condition.js js/allspeak/Value.js js/allspeak/Run.js js/allspeak/Opcodes.js js/allspeak/Language.js js/allspeak/LanguagePack_en.js js/allspeak/Compile.js js/allspeak/Main.js js/allspeak/AllSpeak.js > deploy/dist/allspeak.js

echo "Minimise with closure"
npx google-closure-compiler --js=deploy/dist/allspeak.js --js_output_file=deploy/dist/allspeak-min.js --language_in ECMASCRIPT_2021
echo "Closure finished"

echo "Copy language packs to dist"
cp js/allspeak/LanguagePack_it.js deploy/dist/
cp js/allspeak/LanguagePack_fr.js deploy/dist/
cp js/allspeak/LanguagePack_de.js deploy/dist/
